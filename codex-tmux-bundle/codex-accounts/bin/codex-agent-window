#!/usr/bin/env bash
set -euo pipefail

if [ -z "${TMUX-}" ]; then
  printf 'Run inside tmux.\n' >&2
  exit 1
fi

session="$(tmux display-message -p '#S')"
name="${1:-}"

if [ -z "$name" ]; then
  next="$(tmux list-windows -t "$session" -F '#{window_name}' \
    | awk -F- -v s="$session" '$1==s && $2 ~ /^[0-9]+$/ {if($2>m)m=$2} END {print m+1}')"
  if [ -z "$next" ] || [ "$next" = "0" ]; then
    next=1
  fi
  name="${session}-${next}"
fi

pane_id="$(tmux new-window -P -F "#{pane_id}" -t "$session" -n "$name" "bash -lc 'codex'")"
sleep 0.5
"$HOME/.codex-accounts/bin/codex-agent-sync" "$session" || true
tmux select-window -t "$session:$name"
tmux select-pane -t "$pane_id"
