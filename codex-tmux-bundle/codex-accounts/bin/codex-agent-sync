#!/usr/bin/env bash
set -euo pipefail

force=0
if [ "${1:-}" = "--force" ]; then
  force=1
  shift
fi

session="${1:-}"
if [ -z "$session" ]; then
  if [ -n "${TMUX-}" ]; then
    session="$(tmux display-message -p '#S')"
  else
    printf 'Usage: codex-agent-sync [--force] <session>\n' >&2
    exit 1
  fi
fi

if ! tmux has-session -t "$session" 2>/dev/null; then
  printf 'Session not found: %s\n' "$session" >&2
  exit 1
fi

mapfile -t panes < <(tmux list-panes -t "$session" -F "#{pane_id}\t#{window_name}\t#{window_index}\t#{pane_index}\t#{pane_current_command}")

for line in "${panes[@]}"; do
  IFS=$'\t' read -r pane_id window_name window_index pane_index pane_cmd <<<"$line"
  [ "$pane_cmd" = "codex" ] || continue

  if [ -z "$window_name" ]; then
    window_name="win-${window_index}"
  fi
  pane_name="${window_name}-${pane_index}"

  if [ "$force" -eq 0 ]; then
    synced="$(tmux show-options -p -t "$pane_id" -v @codex_agent_synced 2>/dev/null || true)"
    if [ "$synced" = "1" ]; then
      continue
    fi
  fi

  tmux select-pane -t "$pane_id" -T "$pane_name"
  tmux set-option -p -t "$pane_id" @codex_agent_synced 1

  prompt=$(cat <<EOF
你是子代理：$pane_name
你的上级 window 代理：$window_name
你的上级 session 代理：$session
只需认识上级，无需认识同级。
EOF
)
  tmux send-keys -t "$pane_id" "$prompt" Enter
done
